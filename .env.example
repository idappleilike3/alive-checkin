# ============================================================
# alive_checkin .env (範本,複製成 .env 後填值)
# ============================================================

# --- LINE Bot(您已有) ---
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# --- 簡訊王 kotsms.com.tw ---
# 註冊後從後台「API 設定」取得
SMSKING_USERNAME=
SMSKING_PASSWORD=

# SMS 預設編碼(中文必用 BIG5)
SMSKING_ENCODING=BIG5

# API timeout 秒數
SMSKING_TIMEOUT_SEC=10

# 單則簡訊成本(對帳用)
SMSKING_COST_PER_SMS_NTD=0.85

# --- 失聯預警設定 ---
# T+15 / T+30 分鐘發送第 2 / 第 3 波
ALERT_WAVE_2_DELAY_MINUTES=15
ALERT_WAVE_3_DELAY_MINUTES=30

# 用戶補簽到時,自動取消未送的 wave
ALERT_AUTO_CANCEL_ON_CHECKIN=true

# --- 管理員通知(給自己) ---
# 您的 LINE User ID(不是 Bot ID)
ADMIN_LINE_USER_ID=
# 您 email
ADMIN_EMAIL=

# --- Email SMTP(給管理員 Wave 3 通知) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# --- 守護群(限 799 年費) ---
FEATURE_FLAG_799_ENABLED=true
PHONE_ADDON_RATE_NTD=200

# --- 每月推播配額控管 ---
LINE_PUSH_QUOTA_MONTHLY=15000
SMS_QUOTA_PER_USER_PER_MONTH=100
MONTHLY_REMINDER_CAP_PER_USER=5

# --- 狀態檔路徑 ---
# --- MAKE Webhook ---
# 在 MAKE 建 webhook scenario 後,把 webhook URL 貼這
# 請將真實 Make webhook 放在本機 .env 或 Render Environment,禁止提交到 Git
MAKE_SMS_WEBHOOK_URL=

# --- 狀態檔路徑 ---
STATE_FILE=state.json

# --- Render 部署 ---
APP_PUBLIC_URL=https://alive-checkin.onrender.com

# --- Cron 排程(LOG 級別) ---
LOG_LEVEL=INFO