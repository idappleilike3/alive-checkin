# ============================================================
# alive_checkin .env (绡勬湰,瑜囪＝鎴?.env 寰屽～鍊?
# ============================================================

# --- LINE Bot(鎮ㄥ凡鏈? ---
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# --- 绨¤▕鐜?kotsms.com.tw ---
# 瑷诲唺寰屽緸寰屽彴銆孉PI 瑷畾銆嶅彇寰?SMSKING_USERNAME=
SMSKING_PASSWORD=

# SMS 闋愯ō绶ㄧ⒓(涓枃蹇呯敤 BIG5)
SMSKING_ENCODING=BIG5

# API timeout 绉掓暩
SMSKING_TIMEOUT_SEC=10

# 鍠墖绨¤▕鎴愭湰(灏嶅赋鐢?
SMSKING_COST_PER_SMS_NTD=0.85

# --- 澶辫伅闋愯瑷畾 ---
# T+15 / T+30 鍒嗛悩鐧奸€佺 2 / 绗?3 娉?ALERT_WAVE_2_DELAY_MINUTES=15
ALERT_WAVE_3_DELAY_MINUTES=30

# 鐢ㄦ埗瑁滅敖鍒版檪,鑷嫊鍙栨秷鏈€佺殑 wave
ALERT_AUTO_CANCEL_ON_CHECKIN=true

# --- 绠＄悊鍝￠€氱煡(绲﹁嚜宸? ---
# 鎮ㄧ殑 LINE User ID(涓嶆槸 Bot ID)
ADMIN_LINE_USER_ID=
# 鎮?email
ADMIN_EMAIL=

# --- Email SMTP(绲︾鐞嗗摗 Wave 3 閫氱煡) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# --- 瀹堣缇?闄?799 骞磋不) ---
FEATURE_FLAG_799_ENABLED=true
PHONE_ADDON_RATE_NTD=200

# --- 姣忔湀鎺ㄦ挱閰嶉鎺х ---
LINE_PUSH_QUOTA_MONTHLY=15000
SMS_QUOTA_PER_USER_PER_MONTH=100
MONTHLY_REMINDER_CAP_PER_USER=5

# --- 鐙€鎱嬫獢璺緫 ---
# --- MAKE Webhook ---
# 鍦?MAKE 寤?webhook scenario 寰?鎶?webhook URL 璨奸€?# 璜嬪皣鐪熷 Make webhook 鏀惧湪鏈 .env 鎴?Render Environment,绂佹鎻愪氦鍒?Git
MAKE_SMS_WEBHOOK_URL=

# --- 鐙€鎱嬫獢璺緫 ---
STATE_FILE=state.json

# --- Render 閮ㄧ讲 ---
APP_PUBLIC_URL=https://alive-checkin.onrender.com

# --- LIFF锛堝収宓岋紱姝ｅ紡鐠板瑕?render.yaml /api/config锛?--
# 姘镐箙鎸夐垥璜嬬敤 https://liff.line.me/<LIFF_ID> 锛屽嬁璨煎惈 code=&state= 鐨?OAuth callback
LIFF_ID=2010674803-rK98c0lo

# --- Cron 鎺掔▼(蹇呭～,鏈ō瀹氭檪 cron API 涓€寰?401) ---
CRON_SECRET=
LOG_LEVEL=INFO
# --- Cron 排程(必填,未設定時 cron API 一律 401) ---
CRON_SECRET=

# --- LIFF API 身分驗證(正式環境請設 1) ---
REQUIRE_LIFF_AUTH=1
LINE_LOGIN_CHANNEL_ID=

# --- 藍新 NewebPay（未填則訂單 pending，後台人工確認）---
NEWEBPAY_MERCHANT_ID=
NEWEBPAY_HASH_KEY=
NEWEBPAY_HASH_IV=
NEWEBPAY_STAGE=sandbox

LOG_LEVEL=INFO
